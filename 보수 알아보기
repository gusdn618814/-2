#include <stdio.h>

int main() {

    int x = -1; //여기서 -1을 x로 지정한 이유는 2의보수에서 -1은 비트로 표현하면 모두 1이기 때문에 연산결과를 확인하기 쉽기 때문입니다.
   
    // 2의 보수에서 -1은 비트가 모두 1로 표현되므로 확인하기 쉽게 -1을 x로 지정했습니다.2의 보수방식에서 음수를 만들 때는 양수의 비트를 반전(~),(~이 반전이라는 뜻임.)한 후 1을 더하는 방법을 사용하며 
    //따라서 ~x + 1 이 -x 와 일치할 때 현재 사용중인 시스템이 2의 보수방식을 사용한다고 볼 수 있습니다.
    // 대부분의 컴퓨터는 2의 보수 방식을 사용합니다!
    
    if (~x + 1 == -x) {
        printf("2의 보수입니다.\n");
    }
    else {
        printf("1의 보수입니다.\n");
    }

    return 0;
}
